{
  "title": "Inventory Service — Metrics Dashboard",
  "uid": "inventory-day1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total Inventory Requests by Status",
      "description": "Custom Counter: inventory_requests_total grouped by status tag (success/error)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(inventory_requests_total[1m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Cumulative Request Count by Status",
      "description": "Running total of success vs error requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "inventory_requests_total{status=\"success\"}",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "inventory_requests_total{status=\"error\"}",
          "legendFormat": "Error",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Error" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "description": "Percentage of requests resulting in errors",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * inventory_requests_total{status=\"error\"} / (inventory_requests_total{status=\"success\"} + inventory_requests_total{status=\"error\"})",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Request Duration (p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"inventory-service\"}[1m])) by (le, uri, status))",
          "legendFormat": "p99 {{uri}} {{status}}",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {}
}